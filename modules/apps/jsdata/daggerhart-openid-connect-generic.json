{
  "login_type": "button",
  "login_button_text": "OpenID Connect",
  "client_id": ${jsonencode(authentik_client_id)},
  "client_secret": ${jsonencode(authentik_client_secret)},
  "scope": "openid email profile",
  "endpoint_login": ${jsonencode("${authentik_base_url}/application/o/authorize/")},
  "endpoint_userinfo": ${jsonencode("${authentik_base_url}/application/o/userinfo/")},
  "endpoint_token": ${jsonencode("${authentik_base_url}/application/o/token/")},
  "endpoint_end_session": ${jsonencode("${authentik_base_url}/application/o/${authentik_app_slug}/end-session/")},
  "endpoint_jwks": ${jsonencode("${authentik_base_url}/application/o/${authentik_app_slug}/jwks/")},
  "issuer": ${jsonencode("${authentik_base_url}/application/o/${authentik_app_slug}/")},
  "jwks_cache_ttl": "3600",
  "acr_values": "",
  "identity_key": "sub",
  "http_request_timeout": "5",
  "enforce_privacy": "0",
  "alternate_redirect_uri": "0",
  "nickname_key": "preferred_username",
  "email_format": "{email}",
  "displayname_format": "",
  "identify_with_username": "0",
  "state_time_limit": "180",
  "token_refresh_enable": "1",
  "no_sslverify": "0",
  "allow_internal_idp": "1",
  "link_existing_users": "1",
  "create_if_does_not_exist": "1",
  "redirect_user_back": "1",
  "redirect_on_logout": "1",
  "enable_logging": "1",
  "log_limit": "1000"
}
